@using LostAndFoundTracker.Models.ViewModels
@model ReportItemViewModel
@{
    ViewData["Title"] = "Report an Item";
    Layout = "~/Views/Shared/_Layout.cshtml";
    // Pre‑fill email from session (if not already set in model)
    if (string.IsNullOrEmpty(Model.Email))
    {
        Model.Email = Context.Session.GetString("UserEmail") ?? "";
    }
}

<div class="page-header">
    <h1><i class="fas fa-plus-circle"></i> Report an Item</h1>
    <p>Help your fellow students by reporting lost or found items.</p>
</div>

<div class="form-container">
    <div class="form-header">
        <h2>Item Details</h2>
        <p>Please provide as much information as possible</p>
    </div>
    <div class="form-body">
        <div class="toggle-group">
            <button type="button" id="btnLost" class="toggle-btn" onclick="setType('lost')">
                <i class="fas fa-frown"></i> I LOST an item
            </button>
            <button type="button" id="btnFound" class="toggle-btn" onclick="setType('found')">
                <i class="fas fa-smile"></i> I FOUND an item
            </button>
        </div>
        <span asp-validation-for="ItemType" class="text-danger"></span>

        <form asp-action="ReportItem" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ItemType" id="itemType" />

            <div class="form-group">
                <label><i class="fas fa-tag"></i> Item Name</label>
                <input asp-for="ItemName" placeholder="e.g., Black Wallet, iPhone 14, Student ID" />
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-list"></i> Category</label>
                <select asp-for="Category">
                    <option value="">Select a category</option>
                    <option>Wallet / Purse</option>
                    <option>ID Card</option>
                    <option>Phone / Smartphone</option>
                    <option>Laptop / Tablet</option>
                    <option>Keys</option>
                    <option>Bag / Backpack</option>
                    <option>Clothing</option>
                    <option>Electronics</option>
                    <option>Books</option>
                    <option>Other</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-map-marker-alt"></i> Location</label>
                <input asp-for="Location" placeholder="Where was it lost/found? (e.g., Library, Student Center, Gym)" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-calendar"></i> Date</label>
                <input asp-for="Date" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-align-left"></i> Description</label>
                <textarea asp-for="Description" rows="4" placeholder="Describe the item in detail (color, brand, distinguishing features, etc.)"></textarea>
            </div>

            <div class="form-group">
                <label><i class="fas fa-camera"></i> Upload Photo</label>
                <input asp-for="Photo" accept="image/*" />
                <span asp-validation-for="Photo" class="text-danger"></span>
                <small style="color: #6B7280;">A photo is required and increases chances of recovery by 70%</small>
            </div>

            <div class="form-group">
                <label><i class="fas fa-phone"></i> Contact Number</label>
                <input asp-for="ContactNumber" placeholder="Your phone number" />
                <span asp-validation-for="ContactNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email</label>
                <input asp-for="Email" readonly />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                <i class="fas fa-paper-plane"></i> Submit Report
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function setType(type) {
            document.getElementById('itemType').value = type;
            const lostBtn = document.getElementById('btnLost');
            const foundBtn = document.getElementById('btnFound');
            lostBtn.classList.remove('active-lost', 'active-found');
            foundBtn.classList.remove('active-lost', 'active-found');
            if (type === 'lost') {
                lostBtn.classList.add('active-lost');
            } else {
                foundBtn.classList.add('active-found');
            }
            // Clear validation message for ItemType
            const validationSpan = document.querySelector('span[data-valmsg-for="ItemType"]');
            if (validationSpan) validationSpan.innerText = '';
        }
    </script>
}