@using LostAndFoundTracker.Models
@model List<Item>
@{
    ViewData["Title"] = "Found Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = Context.Session.GetInt32("UserId")?.ToString();
}

<div class="page-header">
    <h1><i class="fas fa-smile"></i> Found Items</h1>
    <p>Items that have been found on campus. Could something here belong to you?</p>
</div>

<!-- Sort Dropdown -->
<div style="display: flex; justify-content: flex-end; margin-bottom: 1rem;">
    <div class="sort-container">
        <label for="sortOrder" style="margin-right: 0.5rem; font-size: 0.8rem; color: #6b7280;">
            <i class="fas fa-sort"></i> Sort by:
        </label>
        <select id="sortOrder" class="sort-select" onchange="window.location.href = this.value;">
            <option value="/Items/FoundItems?sort=recent" selected="@(ViewBag.CurrentSort == "recent")">
                📅 Recent to Oldest
            </option>
            <option value="/Items/FoundItems?sort=oldest" selected="@(ViewBag.CurrentSort == "oldest")">
                📅 Oldest to Recent
            </option>
        </select>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🟢</div>
        <h3>No Found Items Reported</h3>
        <p>There are currently no found items reported. Check back later or report a found item.</p>
        <a href="/Items/ReportItem" class="btn btn-primary" style="margin-top: 1rem;"><i class="fas fa-plus-circle"></i> Report Found Item</a>
    </div>
}
else
{
    <div class="cards-grid">
        @foreach (var item in Model)
        {
            <div class="item-card">
                <div class="card-image" onclick="location.href='/Items/Detail/@item.Id'">
                    @if (!string.IsNullOrEmpty(item.PhotoUrl))
                    {
                        <img src="@item.PhotoUrl" alt="@item.Name" style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <span>🟢</span>
                    }
                </div>
                <div class="card-content">
                    <div class="card-title">@item.Name</div>
                    <div class="card-details">
                        <i class="fas fa-map-marker-alt"></i> @item.Location<br />
                        <i class="fas fa-calendar"></i> @item.Date.ToString("MMM dd, yyyy")<br />
                        <i class="fas fa-tag"></i> @item.Category
                    </div>
                    <span class="badge badge-found">FOUND</span>

                    @if (!string.IsNullOrEmpty(currentUserId) && currentUserId == item.UserId.ToString())
                    {
                        @* Finder's view - their own found items *@
                        if (item.Status == "active")
                        {
                            <button class="btn btn-primary btn-sm btn-block" style="margin-top: 0.75rem; background: #008080;" onclick="markAsClaimed(@item.Id)">
                                <i class="fas fa-gift"></i> Mark as Claimed
                            </button>
                        }
                        else if (item.Status == "claimed")
                        {
                            <div style="margin-top: 0.75rem; padding: 0.5rem; background: #fef3c7; border-radius: 0.5rem; text-align: center; font-size: 0.8rem;">
                                <i class="fas fa-clock"></i> ⏳ Awaiting owner confirmation
                            </div>
                        }
                        else if (item.Status == "returned")
                        {
                            <div style="margin-top: 0.75rem; padding: 0.5rem; background: #d1fae5; border-radius: 0.5rem; text-align: center; font-size: 0.8rem;">
                                <i class="fas fa-check-circle"></i> ✅ Returned! You received @(item.StarRatingGiven ?? 0) stars
                            </div>
                        }
                    }
                    else if (!string.IsNullOrEmpty(currentUserId) && item.Status == "claimed")
                    {
                        @* The owner/claimer sees this - confirm return button *@
                        <button class="btn btn-success btn-sm btn-block" style="margin-top: 0.75rem; background: #10B981;" onclick="showConfirmReturnModal(@item.Id, '@item.Name.Replace("'", "\\'")')">
                            <i class="fas fa-check-double"></i> Confirm I Got It Back
                        </button>
                    }
                    else if (!string.IsNullOrEmpty(currentUserId) && item.Status == "active")
                    {
                        @* Show claim button for active found items *@
                        <button class="btn btn-primary btn-sm btn-block" style="margin-top: 0.75rem; background: #10B981;" onclick="showClaimModal(@item.Id, '@item.Name.Replace("'", "\\'")')">
                            <i class="fas fa-user-check"></i> This Is My Item
                        </button>
                    }
                    else if (!string.IsNullOrEmpty(currentUserId) && item.Status == "returned")
                    {
                        <div style="margin-top: 0.75rem; padding: 0.5rem; background: #d1fae5; border-radius: 0.5rem; text-align: center; font-size: 0.8rem;">
                            <i class="fas fa-check-circle"></i> ✅ Item has been returned
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@Html.AntiForgeryToken()

<!-- Modal for This Is My Item (Claim) -->
<div id="claimModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-user-check"></i> Claim This Item</h3>
            <span class="modal-close" onclick="closeClaimModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>You are claiming: <strong id="claimItemName"></strong></p>
            <p>Your information will be shared with the finder:</p>
            <div class="user-info-preview">
                <p><i class="fas fa-user"></i> Name: <span id="claimUserName"></span></p>
                <p><i class="fas fa-envelope"></i> Email: <span id="claimUserEmail"></span></p>
                <p><i class="fas fa-phone"></i> Phone: <span id="claimUserPhone"></span></p>
            </div>
            <div class="form-group">
                <label><i class="fas fa-comment"></i> Message to Finder:</label>
                <textarea id="claimMessage" class="form-control" rows="3" placeholder="This item belongs to me! Please contact me to return it..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeClaimModal()">Cancel</button>
            <button class="btn btn-primary" onclick="submitClaim()">Send Notification</button>
        </div>
    </div>
</div>

<!-- Confirm Return Modal (Star Rating) -->
<div id="confirmReturnModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-star"></i> Confirm Return & Rate Finder</h3>
            <span class="modal-close" onclick="closeConfirmReturnModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>You have received: <strong id="confirmItemName"></strong></p>
            <p>Thank <strong id="finderName"></strong> for helping you!</p>

            <div class="form-group">
                <label><i class="fas fa-star"></i> Rate the Finder (1-5 stars)</label>
                <div class="star-rating">
                    <span class="star" data-value="1">☆</span>
                    <span class="star" data-value="2">☆</span>
                    <span class="star" data-value="3">☆</span>
                    <span class="star" data-value="4">☆</span>
                    <span class="star" data-value="5">☆</span>
                </div>
                <input type="hidden" id="starRatingValue" name="starRating" value="0" />
                <small style="color: #6B7280;">Your rating helps recognize helpful students!</small>
            </div>

            <div class="form-group">
                <label><i class="fas fa-comment"></i> Thank You Message (Optional):</label>
                <textarea id="thankYouMessage" class="form-control" rows="3" placeholder="Thank you so much for finding my item! I really appreciate your help..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-outline" onclick="closeConfirmReturnModal()">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="submitConfirmReturn()">Send Stars & Confirm</button>
        </div>
    </div>
</div>

<style>
    .modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }

    .modal-content {
        background: white;
        border-radius: 1rem;
        max-width: 500px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        animation: slideIn 0.3s ease;
    }

    .modal-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h3 {
            margin: 0;
            color: #008080;
        }

            .modal-header h3 i {
                margin-right: 0.5rem;
            }

    .modal-close {
        font-size: 1.5rem;
        cursor: pointer;
        color: #6b7280;
    }

        .modal-close:hover {
            color: #374151;
        }

    .modal-body {
        padding: 1.5rem;
    }

    .modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e5e7eb;
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .user-info-preview {
        background: #f0f9f9;
        padding: 1rem;
        border-radius: 0.5rem;
        margin: 1rem 0;
        border-left: 3px solid #008080;
    }

        .user-info-preview p {
            margin: 0.25rem 0;
            font-size: 0.875rem;
        }

        .user-info-preview i {
            width: 20px;
            color: #008080;
        }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            font-size: 0.875rem;
            color: #374151;
        }

            .form-group label i {
                margin-right: 0.5rem;
                color: #008080;
            }

    .form-control {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-family: inherit;
        resize: vertical;
    }

        .form-control:focus {
            outline: none;
            border-color: #008080;
            box-shadow: 0 0 0 3px rgba(0, 128, 128, 0.1);
        }

    /* Star Rating Styles */
    .star-rating {
        display: flex;
        gap: 0.5rem;
        font-size: 1.75rem;
        cursor: pointer;
        margin: 0.5rem 0;
    }

    .star {
        cursor: pointer;
        transition: transform 0.2s;
        color: #d1d5db;
    }

        .star:hover {
            transform: scale(1.2);
        }

    /* Sort Dropdown Styles */
    .sort-container {
        display: flex;
        align-items: center;
        background: white;
        padding: 0.3rem 0.8rem;
        border-radius: 0.5rem;
        border: 1px solid #e5e7eb;
    }

    .sort-select {
        padding: 0.3rem 0.5rem;
        border: none;
        background: transparent;
        font-size: 0.8rem;
        cursor: pointer;
        outline: none;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-50px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 640px) {
        .modal-content {
            width: 95%;
            margin: 1rem;
        }

        .modal-footer {
            flex-direction: column;
        }

            .modal-footer .btn {
                width: 100%;
            }

        .star-rating {
            font-size: 1.25rem;
        }
    }
</style>

@section Scripts {
    <script>
        let currentClaimItemId = 0;
        let currentReturnItemId = 0;

        // ========== MARK AS CLAIMED ==========
        async function markAsClaimed(itemId) {
            if (confirm('Mark this item as claimed? The owner will be notified to confirm pickup and rate you.')) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch(`/Items/MarkClaimed/${itemId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Failed to mark item as claimed.');
                }
            }
        }

        // ========== CLAIM MODAL ==========
        function showClaimModal(itemId, itemName) {
            currentClaimItemId = itemId;
            document.getElementById('claimItemName').textContent = itemName;

            fetch('/Profile/GetCurrentUser')
                .then(res => res.json())
                .then(user => {
                    document.getElementById('claimUserName').textContent = user.fullName;
                    document.getElementById('claimUserEmail').textContent = user.email;
                    document.getElementById('claimUserPhone').textContent = user.contactNumber || 'Not provided';
                })
                .catch(error => {
                    console.error('Error:', error);
                    document.getElementById('claimUserName').textContent = 'Error loading';
                    document.getElementById('claimUserEmail').textContent = 'Error loading';
                    document.getElementById('claimUserPhone').textContent = 'Error loading';
                });

            document.getElementById('claimModal').style.display = 'flex';
            document.getElementById('claimMessage').value = '';
        }

        function closeClaimModal() {
            document.getElementById('claimModal').style.display = 'none';
        }

        async function submitClaim() {
            const message = document.getElementById('claimMessage').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const requestBody = {
                itemId: currentClaimItemId,
                message: message
            };

            try {
                const response = await fetch('/Items/ClaimFound', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(requestBody)
                });

                const result = await response.json();

                if (response.ok) {
                    alert('Notification sent! The finder will contact you soon.');
                    closeClaimModal();
                    location.reload();
                } else {
                    alert(result.error || 'Failed to send notification. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            }
        }

        // ========== CONFIRM RETURN MODAL (STAR RATING) ==========
        function showConfirmReturnModal(itemId, itemName) {
            currentReturnItemId = itemId;
            document.getElementById('confirmItemName').textContent = itemName;

            // Get finder info
            fetch(`/Items/GetFinderInfo/${itemId}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('finderName').textContent = data.finderName;
                })
                .catch(error => {
                    console.error('Error:', error);
                    document.getElementById('finderName').textContent = 'the finder';
                });

            document.getElementById('confirmReturnModal').style.display = 'flex';
            document.getElementById('starRatingValue').value = 0;
            document.getElementById('thankYouMessage').value = '';

            // Reset star rating display
            document.querySelectorAll('.star').forEach(star => {
                star.textContent = '☆';
                star.style.color = '#d1d5db';
            });
        }

        function closeConfirmReturnModal() {
            document.getElementById('confirmReturnModal').style.display = 'none';
        }

        function setStarRating(rating) {
            document.getElementById('starRatingValue').value = rating;
            document.querySelectorAll('.star').forEach((star, index) => {
                if (index < rating) {
                    star.textContent = '★';
                    star.style.color = '#f59e0b';
                } else {
                    star.textContent = '☆';
                    star.style.color = '#d1d5db';
                }
            });
        }

        async function submitConfirmReturn() {
            const starRating = parseInt(document.getElementById('starRatingValue').value);
            if (starRating === 0) {
                alert('Please select a star rating (1-5).');
                return;
            }

            const thankYouMessage = document.getElementById('thankYouMessage').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch(`/Items/ConfirmReturn/${currentReturnItemId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        starRating: starRating,
                        thankYouMessage: thankYouMessage
                    })
                });

                const result = await response.json();

                if (response.ok) {
                    alert('Thank you! The finder has been notified and received stars.');
                    closeConfirmReturnModal();
                    location.reload();
                } else {
                    alert(result.error || 'Failed to confirm return. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            }
        }

        // Attach star click handlers via event delegation
        document.addEventListener('click', function(e) {
            if (e.target.classList && e.target.classList.contains('star')) {
                const value = parseInt(e.target.getAttribute('data-value'));
                setStarRating(value);
            }
        });

        // Close modals when clicking outside
        window.onclick = function(event) {
            const claimModal = document.getElementById('claimModal');
            if (event.target === claimModal) {
                closeClaimModal();
            }
            const confirmModal = document.getElementById('confirmReturnModal');
            if (event.target === confirmModal) {
                closeConfirmReturnModal();
            }
        }
    </script>
}