@using LostAndFoundTracker.Models.ViewModels
@model ReportItemViewModel
@{
    ViewData["Title"] = "Edit Item";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Build the category select list with preselected value
    var categories = new List<SelectListItem>
    {
        new SelectListItem { Value = "", Text = "Select a category" },
        new SelectListItem { Value = "Wallet / Purse", Text = "Wallet / Purse" },
        new SelectListItem { Value = "ID Card", Text = "ID Card" },
        new SelectListItem { Value = "Phone / Smartphone", Text = "Phone / Smartphone" },
        new SelectListItem { Value = "Laptop / Tablet", Text = "Laptop / Tablet" },
        new SelectListItem { Value = "Keys", Text = "Keys" },
        new SelectListItem { Value = "Bag / Backpack", Text = "Bag / Backpack" },
        new SelectListItem { Value = "Clothing", Text = "Clothing" },
        new SelectListItem { Value = "Electronics", Text = "Electronics" },
        new SelectListItem { Value = "Books", Text = "Books" },
        new SelectListItem { Value = "Other", Text = "Other" }
    };
    // Set the selected value based on the model
    foreach (var item in categories)
    {
        item.Selected = (item.Value == Model.Category);
    }
}

<div class="page-header">
    <h1><i class="fas fa-edit"></i> Edit Item</h1>
    <p>Update the details of your reported item.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
}

<div class="form-container">
    <div class="form-header">
        <h2>Item Details</h2>
        <p>Correct any incorrect information.</p>
    </div>
    <div class="form-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label><i class="fas fa-tag"></i> Item Type</label>
                <select asp-for="ItemType" class="form-control" required>
                    <option value="lost">Lost</option>
                    <option value="found">Found</option>
                </select>
                <span asp-validation-for="ItemType" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-tag"></i> Item Name</label>
                <input asp-for="ItemName" class="form-control" required />
                <span asp-validation-for="ItemName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-list"></i> Category</label>
                @Html.DropDownListFor(m => m.Category, categories, new { @class = "form-control", required = "required" })
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-map-marker-alt"></i> Location</label>
                <input asp-for="Location" class="form-control" required />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-calendar"></i> Date</label>
                <input asp-for="Date" type="date" class="form-control" required />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-align-left"></i> Description</label>
                <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-phone"></i> Contact Number</label>
                <input asp-for="ContactNumber" class="form-control" required />
                <span asp-validation-for="ContactNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email</label>
                <input asp-for="Email" type="email" class="form-control" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label><i class="fas fa-camera"></i> New Photo (optional)</label>
                <input asp-for="Photo" type="file" class="form-control-file" accept="image/*" />
                <small class="text-muted">Leave empty to keep the current photo. Upload a new one to replace it.</small>
                <span asp-validation-for="Photo" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Save Changes</button>
            <a href="/Items/Detail/@ViewContext.RouteData.Values["id"]" class="btn btn-outline btn-block">Cancel</a>
        </form>
    </div>
</div>

<style>
    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #E5E7EB;
        border-radius: 0.5rem;
    }

    .form-control-file {
        padding: 0.5rem 0;
    }

    .alert {
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
    }

    .alert-success {
        background-color: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .alert-danger {
        background-color: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .close {
        float: right;
        font-size: 1.25rem;
        font-weight: bold;
        line-height: 1;
        color: inherit;
        opacity: 0.7;
        cursor: pointer;
        background: none;
        border: none;
    }

        .close:hover {
            opacity: 1;
        }

    .text-danger {
        color: #dc2626;
        font-size: 0.8rem;
        margin-top: 0.25rem;
        display: block;
    }
</style>