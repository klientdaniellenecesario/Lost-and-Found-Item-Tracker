@using LostAndFoundTracker.Models
@model List<Item>
@{
    ViewData["Title"] = "Lost Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = Context.Session.GetInt32("UserId")?.ToString();
}

<div class="page-header">
    <h1><i class="fas fa-frown"></i> Lost Items</h1>
    <p>Items that have been reported lost on campus. Help your fellow students find their belongings!</p>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🔴</div>
        <h3>No Lost Items Reported</h3>
        <p>There are currently no lost items reported. Check back later or report a lost item.</p>
        <a href="/Items/ReportItem" class="btn btn-primary" style="margin-top: 1rem;"><i class="fas fa-plus-circle"></i> Report Lost Item</a>
    </div>
}
else
{
    <div class="cards-grid">
        @foreach (var item in Model)
        {
            <div class="item-card" onclick="location.href='/Items/Detail/@item.Id'">
                <div class="card-image">
                    @if (!string.IsNullOrEmpty(item.PhotoUrl))
                    {
                        <img src="@item.PhotoUrl" alt="@item.Name" style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <span>🔴</span>
                    }
                </div>
                <div class="card-content">
                    <div class="card-title">@item.Name</div>
                    <div class="card-details">
                        <i class="fas fa-map-marker-alt"></i> @item.Location<br />
                        <i class="fas fa-calendar"></i> @item.Date.ToString("MMM dd, yyyy")<br />
                        <i class="fas fa-tag"></i> @item.Category
                    </div>
                    <span class="badge badge-lost">LOST</span>

                    @if (!string.IsNullOrEmpty(currentUserId) && currentUserId == item.UserId.ToString())
                    {
                        <button class="btn btn-success btn-sm btn-block" style="margin-top: 0.75rem; background: #10B981;" onclick="markAsFound(@item.Id, event)">
                            <i class="fas fa-check"></i> Mark as Found
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        async function markAsFound(itemId, event) {
            event.stopPropagation();
            if (confirm('Mark this item as found? It will be removed from lost items.')) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch(`/Items/MarkFound/${itemId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Failed to mark item as found.');
                }
            }
        }
    </script>
}