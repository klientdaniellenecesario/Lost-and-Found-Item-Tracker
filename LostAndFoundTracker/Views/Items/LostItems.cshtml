@using LostAndFoundTracker.Models
@model List<Item>
@{
    ViewData["Title"] = "Lost Items";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentUserId = Context.Session.GetInt32("UserId")?.ToString();
}

<div class="page-header">
    <h1><i class="fas fa-frown"></i> Lost Items</h1>
    <p>Items that have been reported lost on campus. Help your fellow students find their belongings!</p>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🔴</div>
        <h3>No Lost Items Reported</h3>
        <p>There are currently no lost items reported. Check back later or report a lost item.</p>
        <a href="/Items/ReportItem" class="btn btn-primary" style="margin-top: 1rem;"><i class="fas fa-plus-circle"></i> Report Lost Item</a>
    </div>
}
else
{
    <div class="cards-grid">
        @foreach (var item in Model)
        {
            <div class="item-card">
                <div class="card-image" onclick="location.href='/Items/Detail/@item.Id'">
                    @if (!string.IsNullOrEmpty(item.PhotoUrl))
                    {
                        <img src="@item.PhotoUrl" alt="@item.Name" style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <span>🔴</span>
                    }
                </div>
                <div class="card-content">
                    <div class="card-title">@item.Name</div>
                    <div class="card-details">
                        <i class="fas fa-map-marker-alt"></i> @item.Location<br />
                        <i class="fas fa-calendar"></i> @item.Date.ToString("MMM dd, yyyy")<br />
                        <i class="fas fa-tag"></i> @item.Category
                    </div>
                    <span class="badge badge-lost">LOST</span>

                    @if (!string.IsNullOrEmpty(currentUserId) && currentUserId == item.UserId.ToString())
                    {
                        <button class="btn btn-success btn-sm btn-block" style="margin-top: 0.75rem; background: #10B981;" onclick="markAsFound(@item.Id)">
                            <i class="fas fa-check"></i> Mark as Found
                        </button>
                    }
                    else if (!string.IsNullOrEmpty(currentUserId))
                    {
                        <button class="btn btn-secondary btn-sm btn-block" style="margin-top: 0.75rem;" onclick="showFoundModal(@item.Id, '@item.Name.Replace("'", "\\'")')">
                            <i class="fas fa-hand-holding-heart"></i> I Found This Item
                        </button>
                    }
                </div>
            </div>
        }
    </div>
}

@Html.AntiForgeryToken()

<!-- Modal for I Found This Item -->
<div id="foundModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-hand-holding-heart"></i> Report Found Item</h3>
            <span class="modal-close" onclick="closeFoundModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>You found: <strong id="modalItemName"></strong></p>
            <p>Your information will be shared with the owner:</p>
            <div class="user-info-preview">
                <p><i class="fas fa-user"></i> Name: <span id="userName"></span></p>
                <p><i class="fas fa-envelope"></i> Email: <span id="userEmail"></span></p>
                <p><i class="fas fa-phone"></i> Phone: <span id="userPhone"></span></p>
            </div>
            <div class="form-group">
                <label><i class="fas fa-comment"></i> Message to Owner:</label>
                <textarea id="foundMessage" class="form-control" rows="3" placeholder="I found your item! Please contact me to arrange pickup..."></textarea>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" onclick="closeFoundModal()">Cancel</button>
            <button class="btn btn-primary" onclick="submitFoundMatch()">Send Notification</button>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }

        .modal-content {
            background: white;
            border-radius: 1rem;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }

        .modal-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .modal-header h3 {
                margin: 0;
                color: #008080;
            }

                .modal-header h3 i {
                    margin-right: 0.5rem;
                }

        .modal-close {
            font-size: 1.5rem;
            cursor: pointer;
            color: #6b7280;
        }

            .modal-close:hover {
                color: #374151;
            }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .user-info-preview {
            background: #f0f9f9;
            padding: 1rem;
            border-radius: 0.5rem;
            margin: 1rem 0;
            border-left: 3px solid #008080;
        }

            .user-info-preview p {
                margin: 0.25rem 0;
                font-size: 0.875rem;
            }

            .user-info-preview i {
                width: 20px;
                color: #008080;
            }

        .form-group {
            margin-bottom: 1rem;
        }

            .form-group label {
                display: block;
                margin-bottom: 0.5rem;
                font-weight: 600;
                font-size: 0.875rem;
                color: #374151;
            }

                .form-group label i {
                    margin-right: 0.5rem;
                    color: #008080;
                }

        .form-control {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #d1d5db;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-family: inherit;
            resize: vertical;
        }

            .form-control:focus {
                outline: none;
                border-color: #008080;
                box-shadow: 0 0 0 3px rgba(0, 128, 128, 0.1);
            }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 640px) {
            .modal-content {
                width: 95%;
                margin: 1rem;
            }

            .modal-footer {
                flex-direction: column;
            }

                .modal-footer .btn {
                    width: 100%;
                }
        }
    </style>

    <script>
        let currentItemId = 0;

        async function markAsFound(itemId) {
            if (confirm('Mark this item as found? It will be removed from lost items.')) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const response = await fetch(`/Items/MarkFound/${itemId}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });
                if (response.ok) {
                    location.reload();
                } else {
                    alert('Failed to mark item as found.');
                }
            }
        }

        function showFoundModal(itemId, itemName) {
            currentItemId = itemId;
            document.getElementById('modalItemName').textContent = itemName;

            fetch('/Profile/GetCurrentUser')
                .then(res => res.json())
                .then(user => {
                    document.getElementById('userName').textContent = user.fullName;
                    document.getElementById('userEmail').textContent = user.email;
                    document.getElementById('userPhone').textContent = user.contactNumber || 'Not provided';
                })
                .catch(error => {
                    console.error('Error:', error);
                    document.getElementById('userName').textContent = 'Error loading';
                    document.getElementById('userEmail').textContent = 'Error loading';
                    document.getElementById('userPhone').textContent = 'Error loading';
                });

            document.getElementById('foundModal').style.display = 'flex';
            document.getElementById('foundMessage').value = '';
        }

        function closeFoundModal() {
            document.getElementById('foundModal').style.display = 'none';
        }

        async function submitFoundMatch() {
            const message = document.getElementById('foundMessage').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const requestBody = {
                itemId: currentItemId,
                message: message
            };

            try {
                const response = await fetch('/Items/ReportFoundMatch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(requestBody)
                });

                const result = await response.json();

                if (response.ok) {
                    alert('Notification sent! The owner will contact you soon.');
                    closeFoundModal();
                } else {
                    alert(result.error || 'Failed to send notification. Please try again.');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('foundModal');
            if (event.target === modal) {
                closeFoundModal();
            }
        }
    </script>
}