﻿@using LostAndFoundTracker.Models.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Campus Lost & Found</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #008080 0%, #20B2AA 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .register-wrapper {
            max-width: 500px;
            width: 100%;
        }

        .brand {
            text-align: center;
            margin-bottom: 2rem;
            color: white;
        }

        .brand-icon {
            width: 80px;
            height: 80px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 1rem;
            color: #008080;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .form-container {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 35px rgba(0,0,0,0.1);
            overflow: hidden;
        }

        .form-header {
            background: #f8fafc;
            padding: 1.5rem;
            border-bottom: 1px solid #e2e8f0;
        }

            .form-header h2 {
                margin: 0 0 0.25rem;
                color: #0f172a;
            }

            .form-header p {
                margin: 0;
                color: #64748b;
                font-size: 0.9rem;
            }

        .form-body {
            padding: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

            .form-group label {
                display: block;
                margin-bottom: 0.5rem;
                font-weight: 500;
                color: #334155;
                font-size: 0.9rem;
            }

                .form-group label i {
                    margin-right: 0.5rem;
                    color: #008080;
                }

            .form-group input, .form-group select {
                width: 100%;
                padding: 0.75rem;
                border: 1px solid #cbd5e1;
                border-radius: 0.5rem;
                font-size: 0.9rem;
                transition: all 0.2s;
                box-sizing: border-box;
            }

                .form-group input:focus {
                    outline: none;
                    border-color: #008080;
                    box-shadow: 0 0 0 3px rgba(0,128,128,0.1);
                }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
            border-radius: 0.5rem;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
        }

        .btn-primary {
            background: #008080;
            color: white;
        }

            .btn-primary:hover {
                background: #006666;
                transform: translateY(-1px);
            }

        .alert {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }
    </style>
</head>
<body>
    <div class="register-wrapper">
        <div class="brand">
            <div class="brand-icon">
                <i class="fas fa-user-plus"></i>
            </div>
            <h1>Join Our Community</h1>
            <p>Create your account to get started</p>
        </div>

        <div class="form-container">
            <div class="form-header">
                <h2>Register</h2>
                <p>Fill in your details below</p>
            </div>
            <div class="form-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-error">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p><i class="fas fa-exclamation-circle"></i> @error.ErrorMessage</p>
                        }
                    </div>
                }

                <form asp-action="Register" method="post">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Full Name</label>
                        <input asp-for="FullName" type="text" placeholder="John Doe" required />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email Address</label>
                        <input asp-for="Email" type="email" placeholder="student@campus.edu" required />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <div style="position: relative;">
                            <input asp-for="Password" type="password" placeholder="Create a password" required style="padding-right: 2.5rem;" />
                            <span onclick="togglePassword('Password')" onmouseover="this.style.color='#008080'" onmouseout="this.style.color='#9ca3af'" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #9ca3af;">
                                <i class="fas fa-eye" id="Password-icon"></i>
                            </span>
                        </div>
                        <small style="color: #6B7280; font-size: 0.7rem;">Password must be at least 6 characters</small>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-check-circle"></i> Confirm Password</label>
                        <div style="position: relative;">
                            <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your password" required style="padding-right: 2.5rem;" />
                            <span onclick="togglePassword('ConfirmPassword')" onmouseover="this.style.color='#008080'" onmouseout="this.style.color='#9ca3af'" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #9ca3af;">
                                <i class="fas fa-eye" id="ConfirmPassword-icon"></i>
                            </span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-user-plus"></i> Create Account
                    </button>
                </form>

                <p style="text-align: center; margin-top: 1.5rem;">
                    Already have an account? <a href="/Account/Login" style="color: #008080; font-weight: 600;">Sign in</a>
                </p>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(fieldName) {
            const input = document.getElementById(fieldName);
            const icon = document.getElementById(fieldName + '-icon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
</body>
</html>