@using LostAndFoundTracker.Models.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Campus Lost & Found</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
            body {
                background: linear-gradient(135deg, #008080 0%, #20B2AA 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1rem;
            }

            .login-wrapper {
                max-width: 450px;
                width: 100%;
            }

            .brand {
                text-align: center;
                margin-bottom: 2rem;
                color: white;
            }

            .brand-icon {
                width: 80px;
                height: 80px;
                background: white;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2.5rem;
                margin: 0 auto 1rem;
                color: #008080;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="brand">
            <div class="brand-icon">
                <i class="fas fa-hand-holding-heart"></i>
            </div>
            <h1>Welcome Back</h1>
            <p>Sign in to access the Lost & Found system</p>
        </div>

        <div class="form-container">
            <div class="form-header">
                <h2>Sign In</h2>
                <p>Enter your campus credentials</p>
            </div>
            <div class="form-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post" autocomplete="off">
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email Address</label>
                        <input asp-for="Email" type="email" placeholder="student@campus.edu" required autocomplete="off" id="emailInput" />
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <input asp-for="Password" type="password" placeholder="Enter your password" required autocomplete="new-password" id="passwordInput" />
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-sign-in-alt"></i> Sign In
                    </button>
                </form>

                <p style="text-align: center; margin-top: 1.5rem;">
                    Don't have an account? <a href="/Account/Register" style="color: #008080; font-weight: 600;">Create one</a>
                </p>
            </div>
        </div>
    </div>

    <script>
            // Force clear fields immediately
            (function() {
                var email = document.getElementById('emailInput');
                var password = document.getElementById('passwordInput');
                if (email) email.value = '';
                if (password) password.value = '';
            })();

            // Also clear after a short delay (for browsers that autofill later)
            setTimeout(function() {
                var email = document.getElementById('emailInput');
                var password = document.getElementById('passwordInput');
                if (email) email.value = '';
                if (password) password.value = '';
            }, 100);

            // Clear again on pageshow (for back/forward navigation)
            window.addEventListener('pageshow', function() {
                var email = document.getElementById('emailInput');
                var password = document.getElementById('passwordInput');
                if (email) email.value = '';
                if (password) password.value = '';
            });
    </script>
</body>
</html>