@using LostAndFoundTracker.Models.ViewModels
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - Campus Lost & Found</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #008080 0%, #20B2AA 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .login-wrapper { max-width: 450px; width: 100%; }
        .brand { text-align: center; margin-bottom: 2rem; color: white; }
        .brand-icon {
            width: 80px; height: 80px; background: white; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem; margin: 0 auto 1rem; color: #008080;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
        .form-container {
            background: white;
            border-radius: 1.5rem;
            box-shadow: 0 20px 35px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .form-header {
            background: #f8fafc;
            padding: 1.5rem;
            border-bottom: 1px solid #e2e8f0;
        }
        .form-header h2 {
            margin: 0 0 0.25rem;
            color: #0f172a;
        }
        .form-header p {
            margin: 0;
            color: #64748b;
            font-size: 0.9rem;
        }
        .form-body {
            padding: 1.5rem;
        }
        .form-group {
            margin-bottom: 1.25rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: #334155;
            font-size: 0.9rem;
        }
        .form-group label i {
            margin-right: 0.5rem;
            color: #008080;
        }
        .form-group input {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid #cbd5e1;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            transition: all 0.2s;
            box-sizing: border-box;
        }
        .form-group input:focus {
            outline: none;
            border-color: #008080;
            box-shadow: 0 0 0 3px rgba(0,128,128,0.1);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.75rem 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
            border-radius: 0.5rem;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
        }
        .btn-primary {
            background: #008080;
            color: white;
        }
        .btn-primary:hover {
            background: #006666;
            transform: translateY(-1px);
        }
        .alert {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
        }
        .alert-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }
        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }
        .btn-block {
            margin-top: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="brand">
            <div class="brand-icon"><i class="fas fa-lock-open"></i></div>
            <h1>New Password</h1>
            <p>Choose a new password for <strong>@Model.Email</strong></p>
        </div>

        <div class="form-container">
            <div class="form-header">
                <h2>Set New Password</h2>
                <p>Enter and confirm your new password</p>
            </div>
            <div class="form-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-error">
                        <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" asp-for="Email" />

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> New Password</label>
                        <div style="position: relative;">
                            <input asp-for="NewPassword" type="password" placeholder="Enter new password" required style="padding-right: 2.5rem;" />
                            <span onclick="togglePassword('NewPassword')" onmouseover="this.style.color='#008080'" onmouseout="this.style.color='#9ca3af'" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #9ca3af;">
                                <i class="fas fa-eye" id="NewPassword-icon"></i>
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Confirm Password</label>
                        <div style="position: relative;">
                            <input asp-for="ConfirmPassword" type="password" placeholder="Repeat new password" required style="padding-right: 2.5rem;" />
                            <span onclick="togglePassword('ConfirmPassword')" onmouseover="this.style.color='#008080'" onmouseout="this.style.color='#9ca3af'" style="position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #9ca3af;">
                                <i class="fas fa-eye" id="ConfirmPassword-icon"></i>
                            </span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block">
                        <i class="fas fa-save"></i> Save New Password
                    </button>
                </form>

                <p style="text-align: center; margin-top: 1.5rem; color: #64748b;">
                    <a href="/Account/Login" style="color: #008080; font-weight: 600; text-decoration: none;">Back to Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <script>
    function togglePassword(fieldName) {
        const input = document.getElementById(fieldName);
        const icon = document.getElementById(fieldName + '-icon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>

</body>
</html>