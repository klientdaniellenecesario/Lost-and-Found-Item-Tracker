@{
ViewData["Title"] = "System History";
Layout = "~/Views/Shared/_Layout.cshtml";
var resolvedItems = ViewBag.ResolvedItems as List<LostAndFoundTracker.Controllers.ResolvedItemDetails>
                    ?? new List<LostAndFoundTracker.Controllers.ResolvedItemDetails>();
var starTransactions = ViewBag.StarTransactions as List<LostAndFoundTracker.Models.StarTransaction>
                       ?? new List<LostAndFoundTracker.Models.StarTransaction>();
}

<div class="page-header">
    <h1><i class="fas fa-history"></i> System History</h1>
    <p>All resolved items and community transactions</p>
</div>

<!-- ========== RESOLVED ITEMS SECTION ========== -->
<div style="background: white; border-radius: 1rem; padding: 1.5rem; margin-bottom: 2rem;">
    <h3 style="margin-bottom: 1rem; color: #008080;">
        <i class="fas fa-check-circle"></i> Resolved Items
    </h3>

    @if (resolvedItems.Any())
    {
        <div class="history-list">
            @foreach (var detail in resolvedItems)
            {
                var item = detail.Item;
                var isLost = item?.Type == "lost";

                <div class="history-card">
                    <!-- Item Image -->
                    <div class="history-card-image">
                        @if (!string.IsNullOrEmpty(item?.PhotoUrl))
                        {
                            <img src="@item.PhotoUrl" alt="@item?.Name" style="width: 100%; height: 100%; object-fit: cover;">
                        }
                        else
                        {
                            <span style="font-size: 2rem;">@(isLost ? "🔴" : "🟢")</span>
                        }
                    </div>

                    <!-- Item Details -->
                    <div class="history-card-content">
                        <div class="history-card-header">
                            <h4>@item?.Name</h4>
                            <span class="badge @(isLost ? "badge-lost" : "badge-found")">
                                @(isLost ? "LOST → FOUND" : "FOUND → CLAIMED")
                            </span>
                        </div>

                        <div class="history-card-details">
                            <p><i class="fas fa-map-marker-alt"></i> @item?.Location</p>
                            <p><i class="fas fa-calendar"></i> Date: @(item?.Date.ToString("MMMM dd, yyyy"))</p>
                            <p><i class="fas fa-check-circle"></i> Resolved: @(item?.ConfirmedReturnDate?.ToString("MMMM dd, yyyy") ?? "Unknown")</p>
                        </div>

                        <!-- Who was involved (names only, no contact) -->
                        <div class="history-card-involved">
                            @if (isLost)
                            {
                                <div class="involved-item">
                                    <i class="fas fa-user-circle"></i>
                                    <span><strong>Reported by:</strong> @detail.Poster?.FullName</span>
                                </div>
                                if (!string.IsNullOrEmpty(detail.HelperName))
                                {
                                    <div class="involved-item">
                                        <i class="fas fa-hand-holding-heart"></i>
                                        <span><strong>Found by:</strong> @detail.HelperName</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="involved-item">
                                    <i class="fas fa-user-circle"></i>
                                    <span><strong>Found by:</strong> @detail.Poster?.FullName</span>
                                </div>
                                if (!string.IsNullOrEmpty(detail.ClaimantName))
                                {
                                    <div class="involved-item">
                                        <i class="fas fa-user-check"></i>
                                        <span><strong>Claimed by:</strong> @detail.ClaimantName</span>
                                    </div>
                                }
                            }

                            @if (detail.StarsGiven.HasValue)
                            {
                                <div class="involved-item stars">
                                    <i class="fas fa-star" style="color: #f59e0b;"></i>
                                    <span><strong>Stars awarded:</strong> @detail.StarsGiven.Value ⭐</span>
                                </div>
                                if (!string.IsNullOrEmpty(detail.ThankYouMessage))
                                {
                                    <div class="thank-you-message">
                                        <i class="fas fa-quote-left"></i> "@detail.ThankYouMessage"
                                    </div>
                                }
                            }
                        </div>

                        <a href="/Items/Detail/@item?.Id" class="btn btn-outline btn-sm">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h3>No Resolved Items Yet</h3>
            <p>When items get resolved, they will appear here.</p>
        </div>
    }
</div>

<!-- ========== STAR TRANSACTIONS SECTION ========== -->
<div style="background: white; border-radius: 1rem; padding: 1.5rem;">
    <h3 style="margin-bottom: 1rem; color: #f59e0b;">
        <i class="fas fa-star"></i> Recent Star Transactions
    </h3>

    @if (starTransactions.Any())
    {
        <div class="transactions-list">
            <table class="transactions-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Giver</th>
                        <th>Receiver</th>
                        <th>Stars</th>
                        <th>Item</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in starTransactions)
                    {
                        <tr>
                            <td class="transaction-date-cell">@transaction.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>@(transaction.Giver?.FullName ?? "Unknown")</td>
                            <td>@(transaction.Receiver?.FullName ?? "Unknown")</td>
                            <td class="transaction-stars-cell">⭐ @transaction.StarsGiven</td>
                            <td>@(transaction.Item?.Name ?? "Unknown")</td>
                            <td class="transaction-message-cell">@(transaction.ThankYouMessage?.Length > 50 ? transaction.ThankYouMessage.Substring(0, 50) + "..." : transaction.ThankYouMessage)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">⭐</div>
            <h3>No Star Transactions Yet</h3>
            <p>When users give stars for returned items, they will appear here.</p>
        </div>
    }
</div>

<style>
    .history-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .history-card {
        display: flex;
        gap: 1.5rem;
        background: #f9fafb;
        border-radius: 1rem;
        overflow: hidden;
        border: 1px solid #e5e7eb;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .history-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

    .history-card-image {
        width: 120px;
        min-width: 120px;
        background: linear-gradient(135deg, #008080, #20B2AA);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

        .history-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .history-card-content {
        flex: 1;
        padding: 1rem 1rem 1rem 0;
    }

    .history-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

        .history-card-header h4 {
            margin: 0;
            font-size: 1.1rem;
            color: #1f2937;
        }

    .history-card-details {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

        .history-card-details p {
            margin: 0;
            font-size: 0.8rem;
            color: #6b7280;
        }

        .history-card-details i {
            width: 20px;
            color: #008080;
        }

    .history-card-involved {
        background: white;
        border-radius: 0.5rem;
        padding: 0.75rem;
        margin: 0.75rem 0;
        border-left: 3px solid #008080;
    }

    .involved-item {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-right: 1rem;
        margin-bottom: 0.5rem;
        font-size: 0.8rem;
    }

        .involved-item i {
            width: 20px;
            color: #008080;
        }

        .involved-item.stars i {
            color: #f59e0b;
        }

    .thank-you-message {
        margin-top: 0.5rem;
        padding: 0.5rem;
        background: #f0f9f9;
        border-radius: 0.5rem;
        font-size: 0.8rem;
        font-style: italic;
        color: #374151;
    }

    .transactions-list {
        overflow-x: auto;
    }

    .transactions-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
    }

        .transactions-table th,
        .transactions-table td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid #e5e7eb;
        }

        .transactions-table th {
            background: #f3f4f6;
            font-weight: 600;
            color: #374151;
        }

    .transaction-date-cell {
        white-space: nowrap;
    }

    .transaction-stars-cell {
        color: #f59e0b;
        font-weight: 600;
    }

    .transaction-message-cell {
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .badge-lost {
        background: #fee2e2;
        color: #dc2626;
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
    }

    .badge-found {
        background: #d1fae5;
        color: #10b981;
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 9999px;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        background: #f9fafb;
        border-radius: 0.75rem;
    }

    .empty-state-icon {
        font-size: 3rem;
        margin-bottom: 0.5rem;
    }

    @@media (max-width: 768px) {
        .history-card {
            flex-direction: column;
        }

        .history-card-image {
            width: 100%;
            height: 150px;
        }

        .history-card-content {
            padding: 1rem;
        }

        .transactions-table {
            font-size: 0.7rem;
        }

            .transactions-table th,
            .transactions-table td {
                padding: 0.5rem;
            }
    }
</style>