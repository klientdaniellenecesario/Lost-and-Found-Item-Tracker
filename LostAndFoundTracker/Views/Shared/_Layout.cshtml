<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Campus Lost & Found</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <style>
        /* (keep all your existing styles – unchanged) */
        .profile-pic-nav {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 0.5rem;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .profile-btn i {
                font-size: 1.2rem;
            }

        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }

        .modal-content {
            background: white;
            border-radius: 1rem;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }

        .modal-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .modal-header h3 {
                margin: 0;
                color: #008080;
            }

        .modal-close {
            font-size: 1.5rem;
            cursor: pointer;
            color: #6b7280;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #008080;
            color: #008080;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 500;
        }

            .btn-outline:hover {
                background: #e6f3f3;
            }

        .btn-primary {
            background: #008080;
            color: white;
            border: none;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 500;
        }

            .btn-primary:hover {
                background: #006666;
            }

        .alert {
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .alert-info {
            background: #e0f2fe;
            color: #075985;
            border: 1px solid #bae6fd;
        }
    </style>
</head>
<body>
    @{
        var isLoggedIn = Context.Session.GetString("UserId") != null;
        var userName = Context.Session.GetString("UserFullName") ?? "Student";
        var profilePicUrl = Context.Session.GetString("UserProfilePic");
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    @if (isLoggedIn)
    {
        <nav class="navbar">
            <div class="nav-container">
                <a href="/Home/Dashboard" class="logo">
                    <div class="logo-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <div class="logo-text"><h1>Campus Lost & Found</h1><p>Reuniting What Matters</p></div>
                </a>
                <div class="nav-links">
                    <a href="/Home/Dashboard" class="@(currentController == "Home" && currentAction == "Dashboard" ? "active" : "")"><i class="fas fa-chart-line"></i> Dashboard</a>
                    <a href="/Items/LostItems" class="@(currentController == "Items" && currentAction == "LostItems" ? "active" : "")"><i class="fas fa-frown"></i> Lost Items</a>
                    <a href="/Items/FoundItems" class="@(currentController == "Items" && currentAction == "FoundItems" ? "active" : "")"><i class="fas fa-smile"></i> Found Items</a>
                    <a href="/Items/ReportItem" class="@(currentController == "Items" && currentAction == "ReportItem" ? "active" : "")"><i class="fas fa-plus-circle"></i> Report</a>
                    <a href="/Search/Index" class="@(currentController == "Search" ? "active" : "")"><i class="fas fa-search"></i> Search</a>
                    <a href="/Notification/Index" class="notification-link @(currentController == "Notification" ? "active" : "")">
                        <i class="fas fa-bell"></i> Notifications
                        <span id="notificationBadge" class="notification-badge" style="display: none;">0</span>
                    </a>
                    <a href="/Profile/Index" class="profile-btn @(currentController == "Profile" ? "active" : "")">
                        @if (!string.IsNullOrEmpty(profilePicUrl))
                        {
                            <img src="@profilePicUrl" alt="Profile" class="profile-pic-nav">
                        }
                        else
                        {

                            <i class="fas fa-user-circle"></i>
                        }
                        @userName
                    </a>
                    <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
                </div>
            </div>
        </nav>
    }
    else
    {
        <nav class="navbar">
            <div class="nav-container">
                <a href="/Home/Landing" class="logo">
                    <div class="logo-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <div class="logo-text"><h1>Campus Lost & Found</h1><p>Reuniting What Matters</p></div>
                </a>
                <div class="nav-links">
                    <a href="/Home/Landing">Home</a>
                    <a href="#how-it-works">How It Works</a>
                    <a href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Sign In</a>
                    <a href="/Account/Register" class="profile-btn"><i class="fas fa-user-plus"></i> Register</a>
                </div>
            </div>
        </nav>
    }

    <main class="main-container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> @TempData["Error"]</div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info"><i class="fas fa-info-circle"></i> @TempData["Info"]</div>
        }
        @RenderBody()
    </main>

    <footer class="footer" style="text-align: center;">
        <p>&copy; 2026 Campus Lost & Found System. All rights reserved. | <a href="#" style="color: white;">Privacy Policy</a> | <a href="#" style="color: white;">Terms of Service</a></p>
    </footer>

    <!-- Global Confirmation Modal (Yes/No) -->
    <div id="globalConfirmModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 450px;">
            <div class="modal-header">
                <h3 id="globalConfirmTitle"><i class="fas fa-question-circle"></i> Confirm Action</h3>
                <span class="modal-close" onclick="closeGlobalConfirmModal()">&times;</span>
            </div>
            <div class="modal-body"><p id="globalConfirmMessage">Are you sure?</p></div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeGlobalConfirmModal()">Cancel</button>
                <button id="globalConfirmOkBtn" class="btn btn-primary">Yes, Proceed</button>
            </div>
        </div>
    </div>

    <!-- Global Message Modal (replaces alert) – with optional callback on OK -->
    <div id="globalMessageModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 400px; text-align: center;">
            <div class="modal-header" style="justify-content: center; border-bottom: none; padding-bottom: 0;">
                <h3 id="messageModalIcon" style="margin: 0; font-size: 2rem;"></h3>
            </div>
            <div class="modal-body">
                <p id="globalMessageText" style="font-size: 1rem; margin: 0;"></p>
            </div>
            <div class="modal-footer" style="justify-content: center;">
                <button id="messageOkBtn" class="btn btn-primary">OK</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        // Confirmation modal (Yes/No)
        function showGlobalConfirm(title, message, onConfirm) {
            const modal = document.getElementById('globalConfirmModal');
            if (!modal) { if (confirm(message)) onConfirm(); return; }
            document.getElementById('globalConfirmTitle').innerHTML = `<i class="fas fa-question-circle"></i> ${escapeHtml(title)}`;
            document.getElementById('globalConfirmMessage').innerHTML = escapeHtml(message);
            const okBtn = document.getElementById('globalConfirmOkBtn');
            const newOkBtn = okBtn.cloneNode(true);
            okBtn.parentNode.replaceChild(newOkBtn, okBtn);
            newOkBtn.onclick = () => {
                closeGlobalConfirmModal();
                if (onConfirm) onConfirm();
            };
            modal.style.display = 'flex';
        }
        function closeGlobalConfirmModal() {
            const modal = document.getElementById('globalConfirmModal');
            if (modal) modal.style.display = 'none';
        }

        // Message modal – stays until OK is clicked, then runs optional callback
        let _messageOkCallback = null;
        function showMessageModal(message, type = 'info', onOk = null) {
            const modal = document.getElementById('globalMessageModal');
            const messageText = document.getElementById('globalMessageText');
            const iconSpan = document.getElementById('messageModalIcon');
            let iconHtml = '';
            if (type === 'success') iconHtml = '<i class="fas fa-check-circle" style="color: #10b981;"></i>';
            else if (type === 'error') iconHtml = '<i class="fas fa-exclamation-circle" style="color: #ef4444;"></i>';
            else iconHtml = '<i class="fas fa-info-circle" style="color: #008080;"></i>';
            iconSpan.innerHTML = iconHtml;
            messageText.innerText = message;
            _messageOkCallback = onOk;
            modal.style.display = 'flex';
        }
        function closeMessageModal() {
            document.getElementById('globalMessageModal').style.display = 'none';
            if (_messageOkCallback) {
                const callback = _messageOkCallback;
                _messageOkCallback = null;
                callback();
            }
        }

        // Prevent backdrop click from closing the modal
        document.getElementById('globalMessageModal').addEventListener('click', function(e) {
            if (e.target === this) return;
        });
        // Attach OK button handler (ensures it works even after dynamic changes)
        document.getElementById('messageOkBtn').onclick = function() {
            closeMessageModal();
        };

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Notification badge
        function loadNotificationCount() {
            fetch('/Notification/GetUnreadCount')
                .then(response => response.json())
                .then(count => {
                    const badge = document.getElementById('notificationBadge');
                    if (badge) {
                        if (count > 0) {
                            badge.textContent = count > 9 ? '9+' : count;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                })
                .catch(error => console.error('Error loading notification count:', error));
        }

        @if (isLoggedIn)
        {
                <text>
                    loadNotificationCount();
                    setInterval(loadNotificationCount, 30000);
                </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>