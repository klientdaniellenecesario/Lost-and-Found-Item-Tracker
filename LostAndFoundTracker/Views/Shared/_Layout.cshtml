<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Campus Lost & Found</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <style>
        /* Profile picture in navbar */
        .profile-pic-nav {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 0.5rem;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .profile-btn i {
                font-size: 1.2rem;
            }

        /* ----- Toast Popup Styles ----- */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 350px;
        }

        .toast {
            background: white;
            border-radius: 0.5rem;
            padding: 1rem 1.25rem;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            animation: slideInRight 0.3s ease forwards;
            border-left: 4px solid;
            font-size: 0.875rem;
        }

            .toast i {
                font-size: 1.25rem;
            }

        .toast-success {
            border-left-color: #10b981;
            background: #f0fdf4;
            color: #065f46;
        }

        .toast-error {
            border-left-color: #ef4444;
            background: #fef2f2;
            color: #991b1b;
        }

        .toast-info {
            border-left-color: #3b82f6;
            background: #eff6ff;
            color: #1e40af;
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes fadeOut {
            to {
                opacity: 0;
                transform: translateX(100%);
            }
        }

        /* ----- Global Modal Styles (reused from earlier views) ----- */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
        }

        .modal-content {
            background: white;
            border-radius: 1rem;
            max-width: 500px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            animation: slideIn 0.3s ease;
        }

        .modal-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .modal-header h3 {
                margin: 0;
                color: #008080;
            }

        .modal-close {
            font-size: 1.5rem;
            cursor: pointer;
            color: #6b7280;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e5e7eb;
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #008080;
            color: #008080;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 500;
        }

            .btn-outline:hover {
                background: #e6f3f3;
            }

        .btn-primary {
            background: #008080;
            color: white;
            border: none;
            border-radius: 0.5rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 500;
        }

            .btn-primary:hover {
                background: #006666;
            }
    </style>
</head>
<body>
    @{
        var isLoggedIn = Context.Session.GetString("UserId") != null;
        var userName = Context.Session.GetString("UserFullName") ?? "Student";
        var profilePicUrl = Context.Session.GetString("UserProfilePic");
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    @if (isLoggedIn)
    {
        <nav class="navbar">
            <div class="nav-container">
                <a href="/Home/Dashboard" class="logo">
                    <div class="logo-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <div class="logo-text">
                        <h1>Campus Lost & Found</h1>
                        <p>Reuniting What Matters</p>
                    </div>
                </a>
                <div class="nav-links">
                    <a href="/Home/Dashboard" class="@(currentController == "Home" && currentAction == "Dashboard" ? "active" : "")"><i class="fas fa-chart-line"></i> Dashboard</a>
                    <a href="/Items/LostItems" class="@(currentController == "Items" && currentAction == "LostItems" ? "active" : "")"><i class="fas fa-frown"></i> Lost Items</a>
                    <a href="/Items/FoundItems" class="@(currentController == "Items" && currentAction == "FoundItems" ? "active" : "")"><i class="fas fa-smile"></i> Found Items</a>
                    <a href="/Items/ReportItem" class="@(currentController == "Items" && currentAction == "ReportItem" ? "active" : "")"><i class="fas fa-plus-circle"></i> Report</a>
                    <a href="/Search/Index" class="@(currentController == "Search" ? "active" : "")"><i class="fas fa-search"></i> Search</a>
                    <a href="/Notification/Index" class="notification-link @(currentController == "Notification" ? "active" : "")">
                        <i class="fas fa-bell"></i> Notifications
                        <span id="notificationBadge" class="notification-badge" style="display: none;">0</span>
                    </a>
                    <a href="/Profile/Index" class="profile-btn @(currentController == "Profile" ? "active" : "")">
                        @if (!string.IsNullOrEmpty(profilePicUrl))
                        {
                            <img src="@profilePicUrl" alt="Profile" class="profile-pic-nav">
                        }
                        else
                        {
                            <i class="fas fa-user-circle"></i>
                        }
                        @userName
                    </a>
                    <a href="/Account/Logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
                </div>
            </div>
        </nav>
    }
    else
    {
        <nav class="navbar">
            <div class="nav-container">
                <a href="/Home/Landing" class="logo">
                    <div class="logo-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <div class="logo-text">
                        <h1>Campus Lost & Found</h1>
                        <p>Reuniting What Matters</p>
                    </div>
                </a>
                <div class="nav-links">
                    <a href="/Home/Landing">Home</a>
                    <a href="#how-it-works">How It Works</a>
                    <a href="/Account/Login"><i class="fas fa-sign-in-alt"></i> Sign In</a>
                    <a href="/Account/Register" class="profile-btn"><i class="fas fa-user-plus"></i> Register</a>
                </div>
            </div>
        </nav>
    }

    <main class="main-container">
        @RenderBody()
    </main>

    <footer class="footer" style="text-align: center;">
        <p>&copy; 2026 Campus Lost & Found System. All rights reserved. | <a href="#" style="color: white;">Privacy Policy</a> | <a href="#" style="color: white;">Terms of Service</a></p>
    </footer>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Global Confirmation Modal -->
    <div id="globalConfirmModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 450px;">
            <div class="modal-header">
                <h3 id="globalConfirmTitle"><i class="fas fa-question-circle"></i> Confirm Action</h3>
                <span class="modal-close" onclick="closeGlobalConfirmModal()">&times;</span>
            </div>
            <div class="modal-body">
                <p id="globalConfirmMessage">Are you sure?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeGlobalConfirmModal()">Cancel</button>
                <button id="globalConfirmOkBtn" class="btn btn-primary">Yes, Proceed</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
    <script src="~/js/site.js"></script>

    <script>
        // ---------- Toast Functions ----------
        function showToast(message, type) {
            const container = document.getElementById('toastContainer');
            if (!container) return;
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            let icon = '';
            if (type === 'success') icon = '<i class="fas fa-check-circle"></i>';
            else if (type === 'error') icon = '<i class="fas fa-exclamation-circle"></i>';
            else icon = '<i class="fas fa-info-circle"></i>';
            toast.innerHTML = `${icon} <span>${escapeHtml(message)}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.animation = 'fadeOut 0.3s ease forwards';
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // ---------- Global Confirmation Modal ----------
        function showGlobalConfirm(title, message, onConfirm) {
            document.getElementById('globalConfirmTitle').innerHTML = `<i class="fas fa-question-circle"></i> ${escapeHtml(title)}`;
            document.getElementById('globalConfirmMessage').innerHTML = escapeHtml(message);
            const modal = document.getElementById('globalConfirmModal');
            const okBtn = document.getElementById('globalConfirmOkBtn');
            const newOkBtn = okBtn.cloneNode(true);
            okBtn.parentNode.replaceChild(newOkBtn, okBtn);
            newOkBtn.onclick = () => {
                closeGlobalConfirmModal();
                if (onConfirm) onConfirm();
            };
            modal.style.display = 'flex';
        }

        function closeGlobalConfirmModal() {
            document.getElementById('globalConfirmModal').style.display = 'none';
        }

        // ---------- TempData / ViewBag Toast ----------
        @{
                var successMsg = TempData["Success"]?.ToString();
                var errorMsg = TempData["Error"]?.ToString();
                var infoMsg = TempData["Info"]?.ToString();
        }
        @if (!string.IsNullOrEmpty(successMsg))
        {
                <text>showToast(@Html.Raw(Json.Serialize(successMsg)), 'success');</text>
        }
        @if (!string.IsNullOrEmpty(errorMsg))
        {
                <text>showToast(@Html.Raw(Json.Serialize(errorMsg)), 'error');</text>
        }
        @if (!string.IsNullOrEmpty(infoMsg))
        {
                <text>showToast(@Html.Raw(Json.Serialize(infoMsg)), 'info');</text>
        }

        // ---------- Notification badge ----------
        function loadNotificationCount() {
            fetch('/Notification/GetUnreadCount')
                .then(response => response.json())
                .then(count => {
                    const badge = document.getElementById('notificationBadge');
                    if (badge) {
                        if (count > 0) {
                            badge.textContent = count > 9 ? '9+' : count;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                })
                .catch(error => console.error('Error loading notification count:', error));
        }

        @if (isLoggedIn)
        {
                <text>
                    loadNotificationCount();
                    setInterval(loadNotificationCount, 30000);
                </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>