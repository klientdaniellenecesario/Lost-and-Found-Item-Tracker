@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userName = Context.Session.GetString("UserFullName") ?? "Student";
}

<div class="hero">
    <h1>Welcome back, @userName! 👋</h1>
    <p>Help your fellow students find their lost items or report something you've found</p>
</div>

<div class="home-cards">
    <a href="/Items/LostItems" class="home-card card-lost">
        <span class="emoji">🔴</span>
        <h3>Lost Items</h3>
        <p>View items that have been reported lost</p>
    </a>

    <a href="/Items/FoundItems" class="home-card card-found">
        <span class="emoji">🟢</span>
        <h3>Found Items</h3>
        <p>View items that have been found</p>
    </a>

    <a href="/Items/ReportItem" class="home-card card-report">
        <span class="emoji">📋</span>
        <h3>Report an Item</h3>
        <p>Report a lost or found item</p>
    </a>

    <a href="/Search" class="home-card card-search">
        <span class="emoji">🔍</span>
        <h3>Search Items</h3>
        <p>Search for specific items</p>
    </a>
</div>