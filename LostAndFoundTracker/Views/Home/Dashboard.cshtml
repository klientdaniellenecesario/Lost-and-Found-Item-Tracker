@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userName = Context.Session.GetString("UserFullName") ?? "Student";
}

<div class="page-header">
    <h1><i class="fas fa-chart-line"></i> Dashboard</h1>
    <p>Welcome back, @userName! Here's an overview of lost and found activity.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-frown"></i></div>
        <div class="stat-value" id="lostCount">0</div>
        <div class="stat-label">Active Lost Items</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-smile"></i></div>
        <div class="stat-value" id="foundCount">0</div>
        <div class="stat-label">Found Items</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-value" id="resolvedCount">0</div>
        <div class="stat-label">Successfully Resolved</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
        <div class="stat-value" id="myItemsCount">0</div>
        <div class="stat-label">Your Reports</div>
    </div>
</div>

<!-- Recent Lost Items Section -->
<div style="background: white; border-radius: 1rem; padding: 1.5rem; margin-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h3 style="margin-bottom: 0; color: #008080;"><i class="fas fa-frown"></i> Recent Lost Items</h3>
        <a href="/Items/LostItems" class="btn btn-sm btn-outline" style="font-size: 0.75rem;">View all →</a>
    </div>
    <div id="recentLostItems" style="margin-top: 1rem;">
        <div class="loading"><div class="spinner"></div> Loading recent lost items...</div>
    </div>
</div>

<!-- Recent Found Items Section -->
<div style="background: white; border-radius: 1rem; padding: 1.5rem; margin-top: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h3 style="margin-bottom: 0; color: #008080;"><i class="fas fa-smile"></i> Recent Found Items</h3>
        <a href="/Items/FoundItems" class="btn btn-sm btn-outline" style="font-size: 0.75rem;">View all →</a>
    </div>
    <div id="recentFoundItems" style="margin-top: 1rem;">
        <div class="loading"><div class="spinner"></div> Loading recent found items...</div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadDashboard() {
            try {
                const response = await fetch('/Home/GetDashboardData');
                const data = await response.json();

                document.getElementById('lostCount').textContent = data.lostCount;
                document.getElementById('foundCount').textContent = data.foundCount;
                document.getElementById('resolvedCount').textContent = data.resolvedCount;
                document.getElementById('myItemsCount').textContent = data.myItemsCount;

                // Render recent lost items
                const lostContainer = document.getElementById('recentLostItems');
                if (data.recentLostItems && data.recentLostItems.length > 0) {
                    lostContainer.innerHTML = renderItemCards(data.recentLostItems);
                } else {
                    lostContainer.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🔴</div><h3>No recent lost items</h3><p>Report a lost item to help others.</p></div>';
                }

                // Render recent found items
                const foundContainer = document.getElementById('recentFoundItems');
                if (data.recentFoundItems && data.recentFoundItems.length > 0) {
                    foundContainer.innerHTML = renderItemCards(data.recentFoundItems);
                } else {
                    foundContainer.innerHTML = '<div class="empty-state"><div class="empty-state-icon">🟢</div><h3>No recent found items</h3><p>Found something? Report it!</p></div>';
                }
            } catch (error) {
                console.error('Error loading dashboard:', error);
                document.getElementById('recentLostItems').innerHTML = '<div class="alert alert-error">Failed to load data.</div>';
                document.getElementById('recentFoundItems').innerHTML = '<div class="alert alert-error">Failed to load data.</div>';
            }
        }

        function renderItemCards(items) {
            return `<div class="cards-grid">
                ${items.map(item => `
                    <div class="item-card" onclick="location.href='/Items/Detail/${item.id}'">
                        <div class="card-image">
                            ${item.photoUrl ? `<img src="${item.photoUrl}" alt="${item.name}" style="width:100%; height:150px; object-fit:cover;">` : (item.type === 'lost' ? '🔴' : '🟢')}
                        </div>
                        <div class="card-content">
                            <div class="card-title">${escapeHtml(item.name)}</div>
                            <div class="card-details">
                                <i class="fas fa-map-marker-alt"></i> ${escapeHtml(item.location)}<br/>
                                <i class="fas fa-calendar"></i> ${escapeHtml(item.date)}
                            </div>
                            <span class="badge ${item.type === 'lost' ? 'badge-lost' : 'badge-found'}">
                                ${item.type === 'lost' ? 'LOST' : 'FOUND'}
                            </span>
                        </div>
                    </div>
                `).join('')}
            </div>`;
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        loadDashboard();
    </script>
}