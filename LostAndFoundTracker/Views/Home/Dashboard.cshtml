@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userName = Context.Session.GetString("UserFullName") ?? "Student";
}

<div class="page-header">
    <h1><i class="fas fa-chart-line"></i> Welcome back, @userName!</h1>
    <p>Here's what's happening with your lost and found activity.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-frown"></i></div>
        <div class="stat-value" id="lostCount">0</div>
        <div class="stat-label">Active Lost Items</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-smile"></i></div>
        <div class="stat-value" id="foundCount">0</div>
        <div class="stat-label">Found Items</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
        <div class="stat-value" id="resolvedCount">0</div>
        <div class="stat-label">Successfully Resolved</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-clipboard-list"></i></div>
        <div class="stat-value" id="myItemsCount">0</div>
        <div class="stat-label">Your Reports</div>
    </div>
</div>

<div class="action-grid">
    <a href="/Items/ReportItem" class="action-card">
        <div class="action-icon">📝</div>
        <h3>Report an Item</h3>
        <p>Lost or found something? Report it now</p>
    </a>
    <a href="/Items/LostItems" class="action-card">
        <div class="action-icon">🔴</div>
        <h3>Browse Lost Items</h3>
        <p>See what others have lost</p>
    </a>
    <a href="/Items/FoundItems" class="action-card">
        <div class="action-icon">🟢</div>
        <h3>Browse Found Items</h3>
        <p>See items that have been found</p>
    </a>
    <a href="/Search" class="action-card">
        <div class="action-icon">🔍</div>
        <h3>Search Items</h3>
        <p>Find specific items quickly</p>
    </a>
</div>

<div style="background: white; border-radius: 1rem; padding: 1.5rem;">
    <h3 style="margin-bottom: 1rem; color: #008080;"><i class="fas fa-clock"></i> Recent Activity</h3>
    <div id="recentItems">
        <div class="loading"><div class="spinner"></div> Loading recent activity...</div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadDashboard() {
            try {
                const response = await fetch('/Home/GetDashboardData');
                const data = await response.json();

                document.getElementById('lostCount').textContent = data.lostCount;
                document.getElementById('foundCount').textContent = data.foundCount;
                document.getElementById('resolvedCount').textContent = data.resolvedCount;
                document.getElementById('myItemsCount').textContent = data.myItemsCount;

                const container = document.getElementById('recentItems');
                if (data.recentItems && data.recentItems.length > 0) {
                    container.innerHTML = `
                        <div class="cards-grid">
                            ${data.recentItems.map(item => `
                                <div class="item-card" onclick="location.href='/Items/Detail/${item.id}'">
                                    <div class="card-image">
                                        ${item.type === 'lost' ? '🔴' : '🟢'}
                                    </div>
                                    <div class="card-content">
                                        <div class="card-title">${item.name}</div>
                                        <div class="card-details">
                                            <i class="fas fa-map-marker-alt"></i> ${item.location}<br/>
                                            <i class="fas fa-calendar"></i> ${item.date}
                                        </div>
                                        <span class="badge ${item.type === 'lost' ? 'badge-lost' : 'badge-found'}">
                                            ${item.type === 'lost' ? 'LOST' : 'FOUND'}
                                        </span>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                } else {
                    container.innerHTML = '<div class="empty-state"><div class="empty-state-icon">📭</div><h3>No recent activity</h3><p>Start by reporting an item!</p></div>';
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        loadDashboard();
    </script>
}